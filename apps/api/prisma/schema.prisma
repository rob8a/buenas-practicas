model unidad_organizacional {
  id                                 Int                                  @id @default(autoincrement()) @db.UnsignedInt
  nombre                             String                               @db.VarChar(255)
  clave                              String?                              @db.VarChar(100)
  id_institucional                   String?                              @db.VarChar(20)
  tipo                               String                               @db.VarChar(100)
  padre_id                           Int?                                 @db.UnsignedInt
  nivel                              Int                                  @default(1) @db.UnsignedTinyInt
  activo                             Boolean                              @default(true)
  created_at                         DateTime                             @default(now()) @db.Timestamp(0)
  updated_at                         DateTime                             @default(now()) @db.Timestamp(0)
  buena_practica                     buena_practica[]
  buena_practica_actor_involucrado   buena_practica_actor_involucrado[]
  buena_practica_unidad_participante buena_practica_unidad_participante[]
  unidad_organizacional              unidad_organizacional?               @relation("unidad_organizacionalTounidad_organizacional", fields: [padre_id], references: [id], map: "fk_unidad_organizacional_padre")
  other_unidad_organizacional        unidad_organizacional[]              @relation("unidad_organizacionalTounidad_organizacional")

  @@index([activo], map: "idx_unidad_organizacional_activo")
  @@index([clave], map: "idx_unidad_organizacional_clave")
  @@index([id_institucional], map: "idx_unidad_organizacional_id_institucional")
  @@index([nombre], map: "idx_unidad_organizacional_nombre")
  @@index([padre_id], map: "idx_unidad_organizacional_padre_id")
  @@index([tipo], map: "idx_unidad_organizacional_tipo")
}

